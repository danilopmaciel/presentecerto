# ============================================================
# PresenteCerto — variáveis de ambiente
# Copie este arquivo para .env.local e preencha os valores.
# Nunca comite .env.local no Git.
# ============================================================

# Supabase (obtenha em https://app.supabase.com → Project → Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...   # server-only, nunca expor no cliente

# URL pública do site (usada para gerar links de RSVP e callbacks de auth)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Chave Pix DO SAAS (sua chave de recebimento das taxas de R$20/R$50 do anfitrião)
# Use uma chave Pix vinculada ao seu CNPJ MEI.
SAAS_PIX_KEY=seu-cnpj-ou-email@exemplo.com
SAAS_PIX_MERCHANT_NAME=PRESENTECERTO
SAAS_PIX_MERCHANT_CITY=SAO PAULO

# ============================================================
# Geração de imagem por IA (plano Temático) — Gemini Nano Banana
# Obtenha a chave em https://aistudio.google.com/app/apikey
# Requer billing ativo no projeto Google Cloud (~US$ 0,03 por imagem).
# ============================================================
GEMINI_API_KEY=AIza...
# (opcional) sobrescreve os modelos tentados, separados por vírgula:
# GEMINI_IMAGE_MODEL=gemini-2.5-flash-image
# (opcional) desliga a UI de IA mesmo no plano Temático:
# NEXT_PUBLIC_AI_GENERATION_ENABLED=false
